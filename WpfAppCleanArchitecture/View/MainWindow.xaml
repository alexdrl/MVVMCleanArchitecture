<Window x:Class="WpfAppCleanArchitecture.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:WpfAppCleanArchitecture.Converters"
        xmlns:vm="clr-namespace:WpfAppCleanArchitecture.ViewModels"
        xmlns:res="clr-namespace:WpfAppCleanArchitecture.Resources"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.WindowTitleMain}" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">
    <Window.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="PlaceholderTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Background">
                        <Setter.Value>
                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                <VisualBrush.Visual>
                                    <TextBlock Foreground="Gray" FontStyle="Italic"
                                               Text="{x:Static res:Strings.PlaceholderSearchCustomer}"
                                               Margin="5,0,0,0"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Toolbar -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10">

            <Button Content="{x:Static res:Strings.ButtonAddCustomer}" Command="{Binding AddCustomerCommand}" Margin="0,0,10,0"/>
            <Button Content="{x:Static res:Strings.ButtonEditCustomer}" Command="{Binding EditCustomerCommand}" Margin="0,0,10,0" IsEnabled="{Binding SelectedCustomer, Converter={StaticResource NullToBoolConverter}}" />
            <Button Content="{x:Static res:Strings.ButtonDeleteCustomer}" Command="{Binding DeleteCustomerCommand}" IsEnabled="{Binding SelectedCustomer, Converter={StaticResource NullToBoolConverter}}" />
            <Button Content="{x:Static res:Strings.ButtonAddOrder}" Command="{Binding AddOrderCommand}"
                    Margin="10,0,0,0"
                    IsEnabled="{Binding SelectedCustomer, Converter={StaticResource NullToBoolConverter}}" />

            <Button Content="{x:Static res:Strings.ButtonLoadCustomers}" Margin="0,0,10,0"
                    Command="{Binding LoadCustomersCommand}" />
            <Button Content="{x:Static res:Strings.ButtonCancel}"
                    Command="{Binding LoadCustomersCancelCommand}" />
        </StackPanel>

        <!-- Error Message -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="10,0,10,4"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Search Bar -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10,0,10,5">
            <TextBox Width="200"
                     Text="{Binding SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource PlaceholderTextBoxStyle}"
                     VerticalContentAlignment="Center"
                     Margin="0,0,5,0"/>
            <Button Content="{x:Static res:Strings.ButtonSearch}"
                    Command="{Binding SearchCustomersCommand}"
                    Margin="0,0,5,0"/>
            <Button Content="{x:Static res:Strings.ButtonClear}"
                    Command="{Binding ClearSearchCommand}"/>
        </StackPanel>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Customers -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnId}" Binding="{Binding Id}" IsReadOnly="True" Width="Auto" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnName}" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnLastName}" Binding="{Binding LastName}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Orders -->
            <DataGrid Grid.Column="1"
                      ItemsSource="{Binding Orders}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnId}" Binding="{Binding Id}" IsReadOnly="True" Width="Auto" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnDescription}" Binding="{Binding Description}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading Spinner Overlay -->
            <Grid Grid.ColumnSpan="2"
                  Visibility="{Binding LoadingService.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                  Background="#88FFFFFF">
                <Border CornerRadius="8" Background="White" Width="100" Height="100"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#DDDDDD" BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="60" Height="8" Margin="0,0,0,8"/>
                        <TextBlock Text="{x:Static res:Strings.StatusLoading}" HorizontalAlignment="Center" FontSize="12" Foreground="#555555"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>

</Window>
